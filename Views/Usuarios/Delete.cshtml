@model MeuProjeto.Models.Usuario

@{
    ViewData["Title"] = "Delete";
}

<h1>Excluir usuário</h1>

<h4>Tem certeza que deseja excluir este usuário?</h4>
<hr />
<div>
    <dl class="row">
        <dt class="col-sm-3">Nome</dt>
        <dd class="col-sm-9">@Model.Nome</dd>

        <dt class="col-sm-3">Perfil</dt>
        <dd class="col-sm-9">@Model.Perfil</dd>
    </dl>
</div>
<form asp-action="Delete">
    <input type="hidden" asp-for="Id" />
    <div class="form-group d-flex gap-2">
        <a asp-action="Index" class="btn btn-info text-white">Voltar</a>
        <input type="submit" value="Excluir" class="btn btn-danger" />
    </div>
</form>